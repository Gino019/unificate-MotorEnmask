# ─────────────────────────────────────────────────────────────────────
# SecOps Universal Monitor — Variables de Entorno
# ─────────────────────────────────────────────────────────────────────
# Copia este archivo como ".env" y NUNCA lo subas a un repositorio.
# Agrega ".env" a tu .gitignore.

# ── Seguridad de Sesiones ─────────────────────────────────────────────
# Genera un valor seguro con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-en-produccion-usa-un-hex-aleatorio-de-64-chars

# Directorio de datos persistentes (Docker usa /app/data automáticamente)
DATA_DIR=.

# ── Admin inicial (solo se crea si no existe) ────────────────────────
ADMIN_EMAIL=admin@secops.local
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Administrador SecOps

# ── URLs de Microservicios ────────────────────────────────────────────
MASKING_SERVICE_URL=http://localhost:8001
MONITOR_SERVICE_URL=http://localhost:8002

# ── PostgreSQL ────────────────────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=postgres

# ── MySQL ─────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=mysql

# ── SQL Server ────────────────────────────────────────────────────────
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=StrongPassword123!
MSSQL_DB=master

# ── MongoDB ───────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=admin

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Neo4j ─────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
