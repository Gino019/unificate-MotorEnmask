# ─────────────────────────────────────────────────────────────────────
# SecOps Universal Monitor — Variables de Entorno
# ─────────────────────────────────────────────────────────────────────
# Copia este archivo como ".env" y NUNCA lo subas a un repositorio.
# Agrega ".env" a tu .gitignore.

# ── Seguridad de Sesiones ─────────────────────────────────────────────
# Genera un valor seguro con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-en-produccion-usa-un-hex-aleatorio-de-64-chars

# ── Google OAuth2 ─────────────────────────────────────────────────────
# Para activar el login con Google:
#   1. Ve a https://console.cloud.google.com/
#   2. Crea un proyecto → Credenciales → "ID de cliente OAuth 2.0" (tipo: Aplicación web)
#   3. Añade en "URIs de redirección autorizados": http://localhost:8000/api/v1/auth/google/callback
#   4. Reemplaza los valores PENDIENTE_CONFIGURAR con los que Google te proporcione.
GOOGLE_CLIENT_ID=PENDIENTE_CONFIGURAR
GOOGLE_CLIENT_SECRET=PENDIENTE_CONFIGURAR
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
